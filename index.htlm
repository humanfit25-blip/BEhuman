<footer class="footer">
  <div class="footer-brand">HUMANFITS</div>
  <div class="footer-copy">Functional Development Program — 2026</div>
</footer>

<script>
function toggleDay(header) {
  header.closest('.day-block').classList.toggle('collapsed');
}

function toggleSession(header) {
  header.closest('.session').classList.toggle('collapsed');
}

function toggleFeedback(toggle) {
  toggle.closest('.feedback-wrapper').classList.toggle('collapsed');
}

document.querySelectorAll('.day-nav a').forEach(link => {
  link.addEventListener('click', e => {
    e.preventDefault();
    const target = document.querySelector(link.getAttribute('href'));
    if (target) {
      const offset = document.querySelector('.day-nav').offsetHeight + 10;
      const y = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
    document.querySelectorAll('.day-nav a').forEach(l => l.classList.remove('active'));
    link.classList.add('active');
  });
});

const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      document.querySelectorAll('.day-nav a').forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === '#' + id);
      });
    }
  });
}, { threshold: 0.2, rootMargin: '-60px 0px 0px 0px' });

document.querySelectorAll('.day-block').forEach(block => observer.observe(block));
</script>

</body>
</html>
